# Глобальные переменные

#MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_LAKEHOUSE=lakehouse
MINIO_BUCKET_WAREHOUSE=warehouse

#Polaris
POLARIS_HOST=polaris
POLARIS_PORT=8181
POLARIS_ADMIN_USER=admin
POLARIS_ADMIN_PASSWORD=password

#Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_RAW_EVENTS=raw-incident-events

#Airflow
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=password

#Spark
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077

#Postgres
PG_POLARIS_USER=polaris
PG_POLARIS_PASSWORD=password
PG_POLARIS_DB=polarisdb
PG_AIRFLOW_USER=airflow
PG_AIRFLOW_PASSWORD=password
PG_AIRFLOW_DB=airflowdb